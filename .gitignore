# Never push secrets
.env
*.env

# Never push personal data
data/.composio/
data/.config/

# OpenClaw runtime state can include secrets, sessions, uploads, and local config.
# Keep only the assignment-safe workspace docs, helper scripts, and custom skills visible.
data/.openclaw/*
!data/.openclaw/workspace/
data/.openclaw/workspace/*
!data/.openclaw/workspace/*.md
!data/.openclaw/workspace/scripts/
!data/.openclaw/workspace/scripts/*.sh
!data/.openclaw/skills/
!data/.openclaw/skills/*/
!data/.openclaw/skills/*/SKILL.md

# Never push cache and build files
data/.cache/
data/.local/
data/.npm/
data/.npm-global/
data/linuxbrew/
data/.bash_history

# Build logs
.build.log
